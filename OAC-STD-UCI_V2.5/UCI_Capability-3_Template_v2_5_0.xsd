	<xs:simpleType name="MsgNameCapabilityEnum">
		<xs:annotation>
			<xs:documentation>*INSTRUCTIONS: Replace the example enumerations with your actual enumerations.  REMOVE INSTRUCTION FROM ANNOTATION.*
			
Category of MsgName Capabilities.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="CAPABILITY_1">
				<xs:annotation>
					<xs:documentation>TYPE 01 CAPABILITY.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="CAPABILITY_2">
				<xs:annotation>
					<xs:documentation>TYPE 02 CAPABILITY.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="MsgNameMessageOutputsEnum">
		<xs:annotation>
			<xs:documentation>*INSTRUCTIONS: Delete the enumerations that you do not need. Add new enums but the values used here must also appear in MessageTypeEnum which is found in the UCI_MessageDefintions xsd file. REMOVE INSTRUCTION FROM ANNOTATION.*
			
Allowable mechanisms for MsgName message outputs.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="ACTION_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated Activity message. For example, the PO_Activity message for a PO Capability.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="AIR_SAMPLE_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated AirSampleActivity message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="AO_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated Activity message.  For example, the ESM_Activity message for an ESM Capability.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="COMM_RELAY_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated CommRelayActivity message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="EA_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated Activity message.  For example, the ESM_Activity message for an ESM Capability.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="EFFECT_ACTIVITY">
				<xs:annotation>
					<xs:documentation>Indicates dynamic status for the Capability will be reported via its associated Activity message. For example, the PO_Activity message for a PO Capability.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY">
				<xs:annotation>
					<xs:documentation>Indicates results of the Capability will be reported via the Entity message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_KINEMATICS_ORBITAL">
				<xs:annotation>
					<xs:documentation>Indicates results of the Capability will be reported via the Entity message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_LOST">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityLost message. This output may be expected if a system is unable to verify the identity of a specific target.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_NOTIFICATION">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the ENTITY_NOTIFICATION message which provides a notification related to an Entity (ex: ORBITAL_BREAKUP, KINEMATICS, ORBITAL_MANEUVER, MISSED_OBSERVATION, NEW).</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_ORBITAL_CSO">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityOrbitalCSO message. This output could result if a series of determinations indicate that multiple resident space objects (RSO) are in close proximity to one another.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_ORBITAL_ELEMENT_SET">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityOrbitalElementSet message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_ORBITAL_EPHEMERIS">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityOrbitalEphemeris message.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_ORBITAL_MANEUVER">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityOrbitalManeuver message. For instance, this output could result when a system has custody of a resident space object (RSO) and observes a sudden change in the object's orbit.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ENTITY_ORBITAL_VCM">
				<xs:annotation>
					<xs:documentation>Indicates results of the capability will be reported via the EntityOrbitalVCM message.</xs:documentation>
				</xs:annotation>
