<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:uci="https://www.vdl.afrl.af.mil/programs/oam" xmlns:xs="http://www.w3.org/2001/XMLSchema" targetNamespace="https://www.vdl.afrl.af.mil/programs/oam" elementFormDefault="qualified" attributeFormDefault="unqualified" version="002.5.0">
